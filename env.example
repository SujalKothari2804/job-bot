# ── Telegram ──────────────────────────────────────────────────────────────────
# Get API_ID and API_HASH from https://my.telegram.org/apps
TG_API_ID=your_api_id_here
TG_API_HASH=your_api_hash_here

# Your personal phone number (for userbot login)
TG_PHONE=+91xxxxxxxxxx

# Create a bot via @BotFather and paste the token here
TG_BOT_TOKEN=123456:ABCdef...

# Source channel to listen to (-100xxxxxxx numeric ID)
TG_SOURCE_CHANNEL=-100xxxxxxxxxx

# Your ReferJobs premium channel (-100xxxxxxx numeric ID)
TG_YOUR_CHANNEL=-100xxxxxxxxxx

# Your personal Telegram user ID (get from @userinfobot)
TG_REVIEWER_ID=your_numeric_user_id

# Session strings — generated by running generate_session.py ONCE on your PC
# Leave blank locally, fill after running generate_session.py
TG_USERBOT_SESSION=
TG_BOT_SESSION=

# ── AI (Gemini Free Tier) ─────────────────────────────────────────────────────
# Get free API key at: aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Gmail ─────────────────────────────────────────────────────────────────────
GMAIL_USER=referjobsco@gmail.com
# Generate App Password at: myaccount.google.com/apppasswords
# (Enable 2FA first, then create App Password for "Mail")
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
